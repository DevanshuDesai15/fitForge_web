# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Hugging Face AI
VITE_HUGGINGFACE_API_KEY=hf_your_huggingface_key
VITE_HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct
VITE_USE_HUGGINGFACE_AI=true
VITE_HUGGINGFACE_TIMEOUT=20000
VITE_HUGGINGFACE_MAX_RETRIES=1
VITE_HUGGINGFACE_TEMPERATURE=0.4
VITE_HUGGINGFACE_MAX_TOKENS=1500
VITE_HUGGINGFACE_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Observability
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional legacy compatibility flags still supported by the AI layer
VITE_GEMINI_PRIORITY=0.4
VITE_HYBRID_MODE=true
